<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Digital Skills Academy</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #f9f9f9;
    }

    header {
      background-color: #004080;
      color: white;
      padding: 1em;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav a {
      margin: 0 10px;
      color: white;
      text-decoration: none;
    }

    .hero img {
      width: 100%;
      border-radius: 10px;
    }

    .featured, .courses-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      padding: 20px;
    }

    .featured img, .courses-grid img {
      width: 100%;
      border-radius: 10px;
      box-shadow: 2px 2px 8px rgba(0,0,0,0.3);
    }

    form {
      display: flex;
      flex-direction: column;
      max-width: 400px;
    }

    form input, form textarea {
      margin-bottom: 10px;
      padding: 10px;
      border-radius: 5px;
      border: 1px solid #ccc;
    }

    button {
      background-color: #004080;
      color: white;
      padding: 10px;
      border: none;
      border-radius: 5px;
    }

    footer {
      background-color: #004080;
      color: white;
      text-align: center;
      padding: 1em;
      margin-top: 20px;
    }

    @media (max-width: 768px) {
      nav {
        display: flex;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
<header>
  <img src="images/logo.png" alt="Academy Logo" class="logo" style="height:50px;">
  <nav>
    <a href="index.html">Home</a>
    <a href="about.html">About</a>
    <a href="courses.html">Courses</a>
    <a href="contact.html">Contact</a>
  </nav>
</header>

<main>
  <!-- Hero Section -->
  <section class="hero">
    <img src="images/banner.jpg" alt="Academy Banner">
    <h1>Welcome to Digital Skills Academy</h1>
    <p>Empowering learners with future-ready skills.</p>
  </section>

  <!-- Featured Courses -->
  <section class="featured">
    <h2>Featured Courses</h2>
    <article>
      <img src="images/webdev.jpg" alt="Web Development">
      <h3>Web Development</h3>
      <p>Learn HTML, CSS, and JavaScript to build modern websites.</p>
    </article>
    <article>
      <img src="images/graphics.jpg" alt="Graphic Design">
      <h3>Graphic Design</h3>
      <p>Master design tools and create stunning visuals.</p>
    </article>
    <article>
      <img src="images/data.jpg" alt="Data Analysis">
      <h3>Data Analysis</h3>
      <p>Analyze and visualize data with modern tools.</p>
    </article>
  </section>

  <!-- Contact Form -->
  <section>
    <h2>Contact Us</h2>
    <form>
      <label for="name">Name:</label>
      <input type="text" id="name" name="name" required>

      <label for="email">Email:</label>
      <input type="email" id="email" name="email" required>

      <label for="message">Message:</label>
      <textarea id="message" name="message" required></textarea>

      <button type="submit">Send</button>
    </form>
  </section>
</main>

<footer>
  <p>&copy; 2026 Digital Skills Academy</p>
</footer>
</body>
</html>
,